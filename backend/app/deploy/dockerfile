# Stage 1: Builder
FROM python:3.11-slim-bookworm as builder

WORKDIR /app

# 1. Install EVERYTHING needed to compile C-extensions
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    gcc \
    libpq-dev \
    python3-dev \
    && rm -rf /var/lib/apt/lists/*

COPY backend/app/requirements.txt .

# 2. CRITICAL: Use 'pip wheel' instead of 'pip download'
# This compiles psycopg2 into a .whl file that is ready for the next stage
RUN pip wheel --no-cache-dir --wheel-dir /app/wheels -r requirements.txt


# Stage 2: Production
FROM python:3.11-slim-bookworm

WORKDIR /app

# 3. Install ONLY the runtime library (libpq5)
# This provides the .so files that the psycopg2 wheel expects to find
RUN apt-get update && apt-get install -y --no-install-recommends \
    libpq5 \
    && rm -rf /var/lib/apt/lists/*

# Copy wheels from builder
COPY --from=builder /app/wheels /app/wheels
COPY backend/app/requirements.txt .

# 4. Install the pre-compiled wheels
RUN pip install --no-cache-dir --no-index --find-links=/app/wheels -r requirements.txt \
    && rm -rf /app/wheels

COPY backend/app/ .

EXPOSE 8000

CMD ["uvicorn", "main:api", "--host", "0.0.0.0", "--port", "8000"]